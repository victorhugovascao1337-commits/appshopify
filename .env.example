# ===== Supabase (banco) =====
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole-aqui-a-service-role-key

# ===== Criptografia dos tokens Shopify (AES-256-GCM) =====
# NÃO troque depois de conectar lojas: os tokens salvos ficam ilegíveis.
ENCRYPTION_KEY=gere-com-openssl-rand-hex-32

# ===== Senha do painel =====
# Obrigatória na Vercel. Troque por uma sua se quiser.
PANEL_PASSWORD=escolha-uma-senha
